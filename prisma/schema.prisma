generator py {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name          String
  email         String  @unique
  emailVerified Boolean @default(false)
  image         String?

  sessions Session[]
  accounts Account[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  token     String  @unique
  ipAddress String?
  userAgent String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id         String @id
  accountId  String
  providerId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?

  scope    String?
  password String?

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id        String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  identifier String
  value      String
  expiresAt  DateTime

  @@index([identifier])
  @@map("verification")
}

model Hackathon {
  id        String   @id @default(uuid())
  name      String?
  createdAt DateTime @default(now())

  saved Boolean @default(false)

  teams          Team[]
  judges         Judge[]
  pptAssignments PptAssignment[]

  @@map("hackathon")
}

model Team {
  teamId    String   @id
  teamName  String?
  createdAt DateTime @default(now())

  hackathonId String?
  hackathon   Hackathon? @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  participant   Participant[]
  teamFeature   TeamFeature?
  teamResult    TeamResult?
  teamSummary   TeamSummary?
  pptSubmission PptSubmission?

  @@map("team")
}

model Participant {
  participantId Int      @id @default(autoincrement())
  createdAt     DateTime @default(now())

  name           String
  githubUsername String? @unique
  linkedInURL    String?
  resumeURL      String?
  phNumber       String?
  email          String? @unique

  teamId String?
  team   Team?   @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  githubProfile GithubProfile?
  githubRepo    GithubRepo[]
  resume        Resume?
  memberScore   MemberScore?

  @@map("participant")
}

model GithubProfile {
  participantId Int @id

  totalRepos      Int?
  originalRepos   Int?
  totalStars      Int?
  totalForks      Int?
  uniqueLanguages Int?
  pushEvents      Int?
  prEvents        Int?
  issueEvents     Int?
  createEvents    Int?
  recentUpdates   Int?
  activityRaw     Float?
  activityScore   Float?

  fetchedAt DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@map("githubProfile")
}

model GithubRepo {
  repoId BigInt  @id
  name   String?

  isFork   Boolean?
  stars    Int?
  forks    Int?
  language String?

  pushedAt DateTime?

  participantId Int?
  participant   Participant? @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@map("githubRepo")
}

model Resume {
  participantId Int @id

  rawText     String?
  resumeScore Float?
  parsedJSON  Json?

  processedAt DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@map("resume")
}

model MemberScore {
  participantId Int @id

  gI Float?
  rI Float?
  cI Float?

  computedAt DateTime @default(now())

  participant Participant @relation(fields: [participantId], references: [participantId], onDelete: Cascade)

  @@map("memberScore")
}

model TeamFeature {
  teamId String @id

  f1  Float?
  f2  Float?
  f3  Float?
  f4  Float?
  f5  Float?
  f6  Float?
  f7  Float?
  f8  Float?
  f9  Float?
  f10 Float?
  f11 Float?
  f12 Float?
  f13 Float?
  f14 Float?
  f15 Float?
  f16 Float?
  f17 Float?

  computedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@map("teamFeature")
}

model TeamResult {
  teamId String @id

  clusterLabel Int?
  level        String?
  teamScore    Float?
  selected     Boolean  @default(false)
  computedAt   DateTime @default(now())

  team Team @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@map("teamResult")
}

model TeamSummary {
  teamId String @id

  summaryText String?
  generatedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  @@map("teamSummary")
}

model Judge {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  name            String
  email           String
  specialisations String[]

  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  assignments PptAssignment[]

  @@map("judge")
}

model PptSubmission {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  fileUrl      String
  categories   String[]
  score        Float?
  classifiedAt DateTime?

  teamId String @unique
  team   Team   @relation(fields: [teamId], references: [teamId], onDelete: Cascade)

  assignment PptAssignment?

  @@map("pptSubmission")
}

model PptAssignment {
  id         String   @id @default(uuid())
  assignedAt DateTime @default(now())

  isPrimaryMatch Boolean @default(true)

  judgeId String
  judge   Judge  @relation(fields: [judgeId], references: [id], onDelete: Cascade)

  pptId String        @unique
  ppt   PptSubmission @relation(fields: [pptId], references: [id], onDelete: Cascade)

  hackathonId String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@map("pptAssignment")
}